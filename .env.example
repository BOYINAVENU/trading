# Polymarket Configuration
PRIVATE_KEY=your_ethereum_private_key_here
POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=137

# Trading Parameters
MAX_POSITION_SIZE_PCT=1.0
MIN_PROBABILITY_THRESHOLD=98.0
TIME_TO_CLOSE_THRESHOLD_MINUTES=5
POLL_INTERVAL_SECONDS=30

# Risk Management
DAILY_LOSS_LIMIT_PCT=5.0
MAX_CONSECUTIVE_LOSSES=3
MIN_BALANCE_USDC=10.0

# API Configuration (Optional - for Riot/Dota live data)
RIOT_API_KEY=your_riot_api_key_here
DOTA_STEAM_API_KEY=your_steam_api_key_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log

# Corporate Network Settings
# Set to True if behind corporate SSL-intercepting proxy
DISABLE_SSL_VERIFICATION=True
